---

<div id="toast-container" class="fixed top-6 right-4 z-9999 flex flex-col gap-3 pointer-events-none" aria-live="polite" aria-atomic="false"></div>

<script>
  (() => {
    const container = document.getElementById('toast-container')!;

    type ToastType = 'success' | 'error' | 'warning' | 'info';

    interface ToastOptions {
      type: ToastType;
      title: string;
      message?: string;
      duration?: number; // ms — 0 = sticky
    }

    const ICONS: Record<ToastType, string> = {
      success: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>`,
      error:   `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>`,
      warning: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>`,
      info:    `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 100 20A10 10 0 0012 2z"/></svg>`,
    };

    // Left accent bar + icon color per type
    const STYLES: Record<ToastType, { bar: string; icon: string }> = {
      success: { bar: 'bg-emerald-400',  icon: 'text-emerald-400' },
      error:   { bar: 'bg-red-400',      icon: 'text-red-400' },
      warning: { bar: 'bg-amber-400',    icon: 'text-amber-400' },
      info:    { bar: 'bg-blue-400',     icon: 'text-blue-400' },
    };

    function dismiss(el: HTMLElement) {
      el.classList.add('toast-exit');
      el.addEventListener('animationend', () => el.remove(), { once: true });
    }

    function show(opts: ToastOptions) {
      const { type, title, message, duration = 5000 } = opts;
      const style = STYLES[type];
      const icon  = ICONS[type];

      const el = document.createElement('div');
      el.className = `
        toast-enter pointer-events-auto
        relative flex items-start gap-3
        rounded-2xl border border-white/10 bg-slate-900/90 backdrop-blur-md
        pl-4 pr-10 py-4 shadow-2xl
        w-80 max-w-[calc(100vw-2rem)]
        overflow-hidden
      `.replace(/\s+/g, ' ').trim();

      el.setAttribute('role', 'alert');

      el.innerHTML = `
        <!-- Left accent bar -->
        <div class="absolute left-0 top-0 bottom-0 w-1 ${style.bar} rounded-l-2xl"></div>

        <!-- Icon -->
        <span class="${style.icon} mt-0.5">${icon}</span>

        <!-- Text -->
        <div class="flex-1 min-w-0">
          <p class="text-sm font-semibold text-white leading-snug">${title}</p>
          ${message ? `<p class="mt-1 text-xs text-white/60 leading-relaxed">${message}</p>` : ''}
        </div>

        <!-- Close button -->
        <button
          class="toast-close absolute top-3 right-3 text-white/30 hover:text-white/80 transition-colors"
          aria-label="Dismiss"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>

        <!-- Progress bar (only when duration > 0) -->
        ${duration > 0 ? `<div class="toast-progress absolute bottom-0 left-0 h-[2px] ${style.bar} opacity-40" style="animation: toast-progress ${duration}ms linear forwards"></div>` : ''}
      `;

      el.querySelector('.toast-close')!.addEventListener('click', () => dismiss(el));
      container.appendChild(el);

      if (duration > 0) {
        setTimeout(() => { if (el.isConnected) dismiss(el); }, duration);
      }

      return el;
    }

    // Convenience wrappers
    (window as any).toast = {
      show,
      success: (title: string, message?: string, duration?: number) => show({ type: 'success', title, message, duration }),
      error:   (title: string, message?: string, duration?: number) => show({ type: 'error',   title, message, duration }),
      warning: (title: string, message?: string, duration?: number) => show({ type: 'warning', title, message, duration }),
      info:    (title: string, message?: string, duration?: number) => show({ type: 'info',    title, message, duration }),
    };
  })();
</script>

<style>
  @keyframes toast-in {
    from { opacity: 0; transform: translateX(110%); }
    to   { opacity: 1; transform: translateX(0); }
  }
  @keyframes toast-out {
    from { opacity: 1; transform: translateX(0); max-height: 120px; margin-bottom: 0; }
    to   { opacity: 0; transform: translateX(110%); max-height: 0; margin-bottom: -0.75rem; }
  }
  @keyframes toast-progress {
    from { width: 100%; }
    to   { width: 0%; }
  }

  .toast-enter { animation: toast-in 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards; }
  .toast-exit  { animation: toast-out 0.3s ease-in forwards; }
</style>