---

---

<!-- Family Reunification CTA Section -->
<section class="relative py-20 md:py-28 overflow-hidden bg-[#313e52] border-t-2 border-b-2 border-white/5">

  <!-- Background texture -->
  <div class="absolute inset-0 opacity-[0.04]"
    style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 32px 32px;"></div>

  <!-- Soft glow blobs -->
  <div class="pointer-events-none absolute -top-40 -left-40 w-150 h-150 rounded-full bg-blue-500/10 blur-[120px]"></div>
  <div class="pointer-events-none absolute -bottom-40 -right-20 w-125 h-125 rounded-full bg-indigo-400/10 blur-[100px]"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4">

    <div class="flex justify-center mb-10">
      <span class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-5 py-2 text-sm text-white/70 backdrop-blur">
        <svg class="w-4 h-4 text-rose-400" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
        </svg>
        <span data-i18n="family.badge">The most important benefit of your visa</span>
      </span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <div>
        <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight tracking-tight" data-i18n="family.title1">
          Your family comes <br/>
          <span class="relative inline-block">
              <span data-i18n="family.title2">with you.</span>
          </span>
          <br/>
          <span data-i18n="family.title3">From the first day.</span>
        </h2>

        <p class="mt-6 text-lg text-white/65 leading-relaxed max-w-lg" data-i18n="family.description">
          <span data-i18n="family.subtitle">All of our programs include complete family reunification. Your spouse and minor children can request their residency permission</span>
          <strong class="text-white font-semibold" data-i18n="family.subtitle2">from the third month of your arrival in France</strong>
          <span data-i18n="family.subtitle3"> — with full access to the educational and health systems.</span>
        </p>

        <!-- Timeline -->
        <div class="mt-10 space-y-0">

          <div class="flex gap-5 items-start group">
            <div class="flex flex-col items-center shrink-0">
              <div class="w-10 h-10 rounded-full bg-blue-500/20 border border-blue-500/40 flex items-center justify-center text-blue-400 font-bold text-sm group-hover:bg-blue-500/30 transition">
                1
              </div>
              <div class="w-px h-12 bg-white/10 mt-1"></div>
            </div>
            <div class="pb-6 pt-1">
              <p class="text-white font-semibold" data-i18n="family.step1.title">You arrive to France</p>
              <p class="text-white/50 text-sm mt-0.5" data-i18n="family.step1.desc">You start your new life with permission to live in France.</p>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="flex gap-5 items-start group">
            <div class="flex flex-col items-center shrink-0">
              <div class="w-10 h-10 rounded-full bg-violet-500/20 border border-violet-500/40 flex items-center justify-center text-violet-400 font-bold text-sm group-hover:bg-violet-500/30 transition">
                3
              </div>
              <div class="w-px h-12 bg-white/10 mt-1"></div>
            </div>
            <div class="pb-6 pt-1">
              <p class="text-white font-semibold" data-i18n="family.step2.title">Mounth 3 - Request your reunification permission</p>
              <p class="text-white/50 text-sm mt-0.5" data-i18n="family.step2.desc">Your spouse and minor children can request their residency permission from the third month of your arrival in France.</p>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="flex gap-5 items-start group">
            <div class="flex flex-col items-center shrink-0">
              <div class="w-10 h-10 rounded-full bg-rose-500/20 border border-rose-500/40 flex items-center justify-center text-rose-400 font-bold text-sm group-hover:bg-rose-500/30 transition">
                ✓
              </div>
            </div>
            <div class="pt-1">
              <p class="text-white font-semibold" data-i18n="family.step3.title">Your family lives with you in France</p>
              <p class="text-white/50 text-sm mt-0.5" data-i18n="family.step3.desc">With your permission, you can access public schools, health services, and the entire European social system.</p>
            </div>
          </div>

        </div>

        <!-- CTA button -->
        <div class="mt-10">
          <a href="/contact"
            class="group inline-flex items-center gap-3 rounded-2xl bg-white px-8 py-4 font-bold text-black hover:bg-blue-50 transition-all hover:scale-[1.03] active:scale-95 shadow-lg shadow-black/20"
            data-i18n="family.cta">
            Consult the process for your family
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- RIGHT: Feature cards grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        <!-- Card: Cónyuge -->
        <div class="rounded-2xl border border-white/10 bg-white/5 backdrop-blur p-6 hover:bg-white/8 hover:border-white/20 transition group">
          <div class="w-11 h-11 rounded-xl bg-blue-500/15 border border-blue-500/25 flex items-center justify-center mb-4 group-hover:scale-110 transition">
            <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="text-white font-semibold text-base" data-i18n="family.card1.title">Spouse included</h3>
          <p class="mt-2 text-white/55 text-sm leading-relaxed" data-i18n="family.card1.desc">Your spouse gets a residency permission, with work authorization from the first day.</p>
        </div>

        <!-- Card: Hijos -->
        <div class="rounded-2xl border border-white/10 bg-white/5 backdrop-blur p-6 hover:bg-white/8 hover:border-white/20 transition group">
          <div class="w-11 h-11 rounded-xl bg-violet-500/15 border border-violet-500/25 flex items-center justify-center mb-4 group-hover:scale-110 transition">
            <svg class="w-5 h-5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
          </div>
          <h3 class="text-white font-semibold text-base" data-i18n="family.card2.title">Children under 18</h3>
          <p class="mt-2 text-white/55 text-sm leading-relaxed" data-i18n="family.card2.desc">Access to public schools, health services, and the entire European social system.</p>
        </div>

        <!-- Card: Desde mes 3 -->
        <div class="rounded-2xl border border-rose-500/20 bg-rose-500/5 backdrop-blur p-6 hover:bg-rose-500/10 transition group sm:col-span-2">
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-rose-500/15 border border-rose-500/25 flex items-center justify-center shrink-0 group-hover:scale-110 transition">
              <svg class="w-5 h-5 text-rose-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-white font-semibold text-base" data-i18n="family.card3.title">
                Group your family
                <span class="text-rose-400" data-i18n="family.card3.title2">3rd month</span>    
              </h3>
              <p class="mt-1 text-white/55 text-sm leading-relaxed" data-i18n="family.card3.desc">
                Start your family group now. We will help you with every step.
              </p>
            </div>
          </div>
        </div>

        <!-- Card: Sin trabajo extra -->
        <div class="rounded-2xl border border-white/10 bg-white/5 backdrop-blur p-6 hover:bg-white/8 hover:border-white/20 transition group">
          <div class="w-11 h-11 rounded-xl bg-emerald-500/15 border border-emerald-500/25 flex items-center justify-center mb-4 group-hover:scale-110 transition">
            <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-white font-semibold text-base" data-i18n="family.card4.title">Work authorization included</h3>
          <p class="mt-2 text-white/55 text-sm leading-relaxed" data-i18n="family.card4.desc">Your spouse gets work authorization from the first day.</p>
        </div>

        <!-- Card: Salud + Educación -->
        <div class="rounded-2xl border border-white/10 bg-white/5 backdrop-blur p-6 hover:bg-white/8 hover:border-white/20 transition group">
          <div class="w-11 h-11 rounded-xl bg-amber-500/15 border border-amber-500/25 flex items-center justify-center mb-4 group-hover:scale-110 transition">
            <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
          </div>
          <h3 class="text-white font-semibold text-base" data-i18n="family.card5.title">Health and education services</h3>
          <p class="mt-2 text-white/55 text-sm leading-relaxed" data-i18n="family.card5.desc">Access to the Social Security System and public French schools — free of charge.</p>
        </div>

      </div>
    </div>

    <!-- Bottom stats bar -->
    <div class="mt-16 pt-10 border-t border-white/10 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <div>
        <div class="text-3xl font-bold text-white" data-i18n="family.stat1.value">3 months</div>
        <div class="text-sm text-white/45 mt-1" data-i18n="family.stat1.label">to start your family group</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-white" data-i18n="family.stat2.value">100%</div>
        <div class="text-sm text-white/45 mt-1" data-i18n="family.stat2.label">includes family programs</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-white" data-i18n="family.stat3.value">+16k</div>
        <div class="text-sm text-white/45 mt-1" data-i18n="family.stat3.label">families registered</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-white" data-i18n="family.stat4.value">4 years</div>
        <div class="text-sm text-white/45 mt-1" data-i18n="family.stat4.label">renewable Passeport Talent permission</div>
      </div>
    </div>

  </div>
</section>