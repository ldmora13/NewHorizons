---
import MainLayout from "../layouts/MainLayout.astro";
const backgroundImage = "/img/passport-european-map.jpg";
---

<MainLayout title="Payment Successful | New Horizons">
  <section class="min-h-screen py-24 flex items-center justify-center">
    <div class="max-w-xl w-full mx-4">

      <!-- FALLBACK: shown on direct nav / refresh (no sessionStorage data) -->
      <div id="fallback-view" class="hidden text-center space-y-6 py-20">
        <div class="w-16 h-16 rounded-full bg-white/10 border border-white/20 flex items-center justify-center mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-3-3v6m9-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h2 class="text-2xl font-semibold text-white">No receipt data found</h2>
        <p class="text-white/50 text-sm max-w-xs mx-auto">
          This page requires a completed payment to display.
          If you believe this is an error, please contact support.
        </p>
        <a href="/"
          class="inline-flex items-center gap-2 rounded-xl bg-white px-6 py-3 text-sm font-bold text-black hover:bg-white/90 transition">
          Return to Home
        </a>
      </div>

      <!-- TICKET: shown after successful payment -->
      <div id="ticket"
        class="bg-white rounded-3xl overflow-hidden shadow-2xl opacity-0 translate-y-4 transition-all duration-500">

        <!-- Header with background image -->
        <div class="relative p-8 text-center text-white"
          style={`background-image: url('${backgroundImage}'); background-size: cover; background-position: center;`}>
          <div class="absolute inset-0 bg-black/55"></div>
          <div class="relative z-10">
            <div class="w-20 h-20 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-4 backdrop-blur-sm border border-white/30">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <h1 class="text-3xl font-bold uppercase tracking-wider">Payment Successful</h1>
            <p class="text-blue-100 mt-1 text-sm">Your immigration process has started.</p>
          </div>
        </div>

        <!-- Body -->
        <div class="p-8 space-y-8 bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [bg-size-[16px_16px]]">

          <!-- Amount -->
          <div class="text-center pb-8 border-b border-dashed border-gray-300">
            <p class="text-gray-400 uppercase text-xs font-bold tracking-widest mb-1">Amount Paid</p>
            <h2 class="text-5xl font-black text-gray-900">
              $<span id="display-amount">0.00</span>
              <span class="text-lg font-medium text-gray-400">USD</span>
            </h2>
          </div>

          <!-- Details grid -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <p class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-1">Client</p>
              <p id="display-client" class="text-gray-800 font-medium">—</p>
            </div>
            <div>
              <p class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-1">Program</p>
              <p id="display-service" class="text-gray-800 font-medium">—</p>
            </div>
            <div>
              <p class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-1">File Reference</p>
              <p id="display-id" class="text-gray-800 font-mono text-sm break-all">—</p>
            </div>
            <div>
              <p class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-1">Date</p>
              <p id="display-date" class="text-gray-800 font-medium">—</p>
            </div>
            <div>
              <p class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-1">Family</p>
              <p id="display-family" class="text-gray-800 font-medium">—</p>
            </div>
            <div>
              <p class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-1">Status</p>
              <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-semibold bg-emerald-100 text-emerald-800">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                Confirmed
              </span>
            </div>
          </div>

          <!-- New user: account credentials -->
          <div id="new-user-box" class="hidden bg-blue-50 border border-blue-200 rounded-2xl p-5 space-y-3">
            <p class="text-blue-800 font-semibold text-sm">Your account has been created</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
              <div>
                <span class="text-blue-500 text-xs uppercase font-bold tracking-wider block mb-0.5">Email</span>
                <span id="display-email" class="text-blue-900 font-mono break-all">—</span>
              </div>
              <div>
                <span class="text-blue-500 text-xs uppercase font-bold tracking-wider block mb-0.5">Temp Password</span>
                <span id="display-password" class="text-blue-900 font-mono font-bold">—</span>
              </div>
            </div>
            <p class="text-blue-600 text-xs">
              Save these credentials. You will be prompted to change your password on first login.
            </p>
          </div>

          <!-- Returning user: email confirmation -->
          <div id="returning-user-box" class="hidden bg-gray-50 border border-gray-200 rounded-2xl p-4">
            <p class="text-gray-600 text-sm text-center">
              A confirmation has been sent to
              <strong id="display-email-returning" class="text-gray-800">your email</strong>.
            </p>
          </div>

          <!-- Actions -->
          <div class="pt-2 flex flex-col sm:flex-row gap-3 no-print">
            <button onclick="window.print()"
              class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-800 font-bold py-3 px-6 rounded-xl transition flex items-center justify-center gap-2 text-sm">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
              </svg>
              Print Receipt
            </button>
            <a href="/"
              class="flex-1 bg-slate-900 hover:bg-slate-800 text-white font-bold py-3 px-6 rounded-xl transition text-center text-sm">
              Return to Home
            </a>
          </div>
        </div>

        <!-- Jagged bottom edge -->
        <div class="h-4 bg-gray-200 w-full"
          style="clip-path: polygon(0% 0%,5% 100%,10% 0%,15% 100%,20% 0%,25% 100%,30% 0%,35% 100%,40% 0%,45% 100%,50% 0%,55% 100%,60% 0%,65% 100%,70% 0%,75% 100%,80% 0%,85% 100%,90% 0%,95% 100%,100% 0%)">
        </div>
      </div>

    </div>
  </section>
</MainLayout>

<script>
  window.addEventListener('DOMContentLoaded', () => {
    const ticket       = document.getElementById('ticket')!;
    const fallbackView = document.getElementById('fallback-view')!;

    // Read + immediately consume the session payload
    let payload: Record<string, any> | null = null;
    try {
      const raw = sessionStorage.getItem('nh_tx_success');
      if (raw) {
        payload = JSON.parse(raw);
        sessionStorage.removeItem('nh_tx_success');
      }
    } catch (e) {
      console.warn('[PaymentSuccess] Could not parse session data:', e);
    }

    if (!payload) {
      ticket.classList.add('hidden');
      fallbackView.classList.remove('hidden');
      return;
    }

    // ── Populate fields ──────────────────────────────────────────────────────
    function setText(id: string, value: string) {
      const el = document.getElementById(id);
      if (el) el.textContent = value;
    }

    const amount = payload.amountPaid?.toLocaleString('en-US', {
      minimumFractionDigits: 2, maximumFractionDigits: 2
    }) ?? '0.00';

    setText('display-amount',  amount);
    setText('display-client',  payload.clientName   ?? '—');
    setText('display-service', payload.programLabel ?? payload.programId ?? '—');
    setText('display-id',      payload.ticketId ? `EXP-${payload.ticketId}` : (payload.paypalOrderId || '—'));

    const dateObj = payload.paymentDate ? new Date(payload.paymentDate) : new Date();
    setText('display-date', dateObj.toLocaleString('en-US', {
      year: 'numeric', month: 'long', day: 'numeric',
      hour: '2-digit', minute: '2-digit',
    }));

    const adults   = payload.adults   ?? 1;
    const children = payload.children ?? 0;
    const familyStr = `${adults} adult${adults !== 1 ? 's' : ''}` +
      (children > 0 ? `, ${children} child${children !== 1 ? 'ren' : ''}` : '');
    setText('display-family', familyStr);

    // Account info boxes (mutually exclusive)
    if (payload.isNewUser && payload.tempPassword) {
      document.getElementById('new-user-box')!.classList.remove('hidden');
      setText('display-email',    payload.userEmail    ?? '—');
      setText('display-password', payload.tempPassword ?? '—');
    } else {
      document.getElementById('returning-user-box')!.classList.remove('hidden');
      setText('display-email-returning', payload.userEmail ?? 'your email');
    }

    // Animate ticket entrance
    requestAnimationFrame(() => {
      setTimeout(() => {
        ticket.classList.remove('opacity-0', 'translate-y-4');
        ticket.classList.add('opacity-100', 'translate-y-0');
      }, 80);
    });
  });
</script>

<style>
  @media print {
    .no-print { display: none !important; }
    body       { background: white !important; }
    section    { padding: 0 !important; background: none !important; }
    #ticket    { box-shadow: none !important; border: 1px solid #e5e7eb; }
  }
</style>